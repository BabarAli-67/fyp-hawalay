# Copy to .env and fill in real values. Never commit .env.

# HTTP
PORT=5000
# Frontend origin(s) for CORS — comma-separated, no trailing slash
# Production: https://your-app.vercel.app
# Optional previews: set CORS_ALLOW_VERCEL_PREVIEWS=true
CLIENT_URL=http://localhost:5173

# MongoDB (e.g. mongodb+srv://user:pass@cluster/dbname)
MONGO_URI=

# Auth (signing access tokens — use a long random string in production)
JWT_SECRET=
# Access token lifetime (jsonwebtoken format, e.g. 7d, 24h)
JWT_EXPIRES=7d

# Internal service-to-service or admin hooks (shared secret header)
INTERNAL_SECRET=

# Python FastAPI sidecar (no trailing slash) — OCR, BLIP, CLIP, matching
# HF_TOKEN is configured in ai-server/.env only (Express does not use it)
FASTAPI_URL=http://127.0.0.1:8000

# Email verification (OTP) — SMTP (e.g. Gmail, SendGrid, Mailgun)
# For local dev without SMTP, set EMAIL_VERIFICATION_DEV_LOG=true (OTP printed in server console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Hawalay <noreply@example.com>"
EMAIL_VERIFICATION_DEV_LOG=false
OTP_EXPIRY_MINUTES=10

# Google OAuth (Web client ID)
GOOGLE_CLIENT_ID=

# Optional - web push (generate keys with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=noreply@example.com

# Optional - object_v1 detector artifacts (shared with ai-server; replace files, restart — no code changes)
# Defaults point to ../ai-server/artifacts/object_v1/
# OBJECT_MODEL_PATH=../ai-server/artifacts/object_v1/weights/best.pt
# OBJECT_CLASS_NAMES_PATH=../ai-server/artifacts/object_v1/class_names.json
# OBJECT_CATEGORY_MAP_PATH=../ai-server/artifacts/object_v1/category_map.json

# Copy to .env and fill in real values. Never commit .env.

# HTTP
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB (e.g. mongodb+srv://user:pass@cluster/dbname)
MONGO_URI=

# Auth (signing access/refresh tokens — use a long random string in production)
JWT_SECRET=

# Internal service-to-service or admin hooks (shared secret header)
INTERNAL_SECRET=

# Hugging Face API (AI features)
HF_TOKEN=

# Python FastAPI sidecar / ML service base URL (no trailing slash)
FASTAPI_URL=http://127.0.0.1:8000

# Google OAuth (Web client ID)
GOOGLE_CLIENT_ID=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact / mailto for push subscription (RFC requirement)
VAPID_EMAIL=mailto:admin@example.com

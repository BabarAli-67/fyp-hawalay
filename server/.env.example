# Copy to .env and fill in real values. Never commit .env.

# HTTP
PORT=5000
# Frontend origin(s) for CORS — comma-separated, no trailing slash
# Production: https://your-app.vercel.app
# Optional previews: set CORS_ALLOW_VERCEL_PREVIEWS=true
CLIENT_URL=http://localhost:5173

# MongoDB (e.g. mongodb+srv://user:pass@cluster/dbname)
MONGO_URI=

# Auth (signing access/refresh tokens — use a long random string in production)
JWT_SECRET=

# Internal service-to-service or admin hooks (shared secret header)
INTERNAL_SECRET=

# Hugging Face API (AI features). Use a placeholder until you add a real token:
# HF_TOKEN=dev-placeholder
HF_TOKEN=dev-placeholder

# Python FastAPI sidecar / ML service base URL (no trailing slash)
FASTAPI_URL=http://127.0.0.1:8000

# Email verification (OTP) — SMTP (e.g. Gmail, SendGrid, Mailgun)
# For local dev without SMTP, set EMAIL_VERIFICATION_DEV_LOG=true (OTP printed in server console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Hawalay <noreply@example.com>"
EMAIL_VERIFICATION_DEV_LOG=false
OTP_EXPIRY_MINUTES=10

# Google OAuth (Web client ID)
GOOGLE_CLIENT_ID=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact / mailto for push subscription (RFC requirement)
VAPID_EMAIL=mailto:admin@example.com

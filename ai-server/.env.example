# AI server (FastAPI) — copy to .env

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Express API origin for CORS (no trailing slash)
NODE_SERVER_URL=http://localhost:5000

# Shared with MERN (matching module / Flow 4)
MONGO_URI=mongodb://127.0.0.1:27017/fyp-hawalay
MONGO_DB_NAME=fyp-hawalay

# Service-to-service auth — must match server/.env INTERNAL_SECRET
INTERNAL_SECRET=

# Google Gemini — https://aistudio.google.com/apikey
# Captioning + text/image embeddings (required for /ai/analyze-image and /ai/process-image)
GEMINI_API_KEY=
# HF_TOKEN not used in ai-server — Gemini handles captioning + embeddings
# gemini-1.5-flash is retired; use gemini-2.0-flash or gemini-2.5-flash
GEMINI_CAPTION_MODEL=gemini-2.0-flash
# Alias: GEMINI_MODEL (same as GEMINI_CAPTION_MODEL)
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# Alias: GEMINI_EMBED_MODEL (same as GEMINI_EMBEDDING_MODEL)
PIPELINE_VERSION=analyze_v1

# Gemini usage controls (read by ai-server ONLY — server/.env copies are ignored)
GEMINI_GENERATE_MAX_ATTEMPTS=1
# Free tier defaults (1 caption call per upload). Paid tier: MAX_ATTEMPTS=3, QUALITY_RETRY=true, MAX_PASSES=3, TOKENS=512
GEMINI_CAPTION_QUALITY_RETRY=false
GEMINI_CAPTION_MAX_PASSES=1
GEMINI_CAPTION_MAX_OUTPUT_TOKENS=256
GEMINI_FEATURES_ENABLED=true
GEMINI_EMBED_IMAGE=false
# Retries: each HTTP call retries on 429/500/502/503/504 with exponential backoff

# Matching defaults (Flow 4)
SIMILARITY_THRESHOLD=0.70
MATCH_RADIUS_METERS=10000
MATCH_LIMIT=5
MAX_MATCH_CANDIDATES=100
DATE_WINDOW_DAYS=7
CATEGORY_BONUS=0.10
LOCATION_WEIGHT=0.25

# YOLO weights (best.pt) — required for region-based OCR
# Local dev (from repo root OCR_Model):
# YOLO_WEIGHTS_PATH=../OCR_Model/cnic-creditcard-model-training-main/cnic-creditcard-model-training-main/training/runs/detect/runs/detect/card_detection-8/weights/best.pt
# Docker / Hugging Face Space (upload best.pt to artifacts/ocr/weights/):
# YOLO_WEIGHTS_PATH=/app/artifacts/ocr/weights/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_USE_GPU=false

# EasyOCR
EASYOCR_LANGS=en
EASYOCR_USE_GPU=false

# Object detector (object_v1) — InceptionV3 Keras classifier (299×299 input)
# Trained with tensorflow==2.20.0, keras==3.12.0 — use Python 3.10–3.12 for ai-server.
# Plug-and-play: replace these three files and restart (no code changes)
#   artifacts/object_v1/weights/hawalay_final_model.keras
#   artifacts/object_v1/class_names.json   ← 13 classes (alphabetical training order)
#   artifacts/object_v1/category_map.json    ← class name → report category
# OBJECT_MODEL_PATH=artifacts/object_v1/weights/hawalay_final_model.keras
# OBJECT_CLASS_NAMES_PATH=artifacts/object_v1/class_names.json
# OBJECT_CATEGORY_MAP_PATH=artifacts/object_v1/category_map.json
OBJECT_CONFIDENCE_THRESHOLD=0.5
OBJECT_USE_GPU=false

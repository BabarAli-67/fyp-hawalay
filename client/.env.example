# Client (Vite) — copy to `.env` and adjust.
# API base URL for axios (no trailing slash required).
# Vercel: set the same keys in Project → Settings → Environment Variables, then redeploy.
# Production: https://your-service.onrender.com (must be https)
VITE_API_URL=http://localhost:5000

# Same Web Client ID as server GOOGLE_CLIENT_ID. In Google Cloud Console add
# Authorized JavaScript origins: http://localhost:5173 and https://your-app.vercel.app
# VITE_GOOGLE_CLIENT_ID=

# Maps: Hawalay uses free OpenStreetMap + Leaflet (no API key). See client/src/components/Map.jsx.
